  "scorecard_contract": {
    "headline_formula": "CodeMarkScore = gate * geometric_mean(headline_core_score, headline_generalization)",
    "headline_soft_floor_epsilon": 0.05,
    "core_score_components": [
      "detection_separability",
      "robustness",
      "utility",
      "stealth_conditioned",
      "efficiency_conditioned"
    ],
    "notes": {
      "headline_layers": "headline_core_score and headline_generalization are public headline-only transforms used only for CodeMarkScore composition; strict/raw diagnostics remain separately released through raw_* fields so unsupported or structurally weak slices stay auditable rather than looking perfect. raw_composite_strict stays fail-closed and does not reuse the softened headline layers.",
      "public_vs_strict": "released score surfaces are intentionally split between strict/raw diagnostics and public summary fields. Public robustness/utility/generalization summarize supported evidence, while separate *_support_rate and *_status fields expose coverage and support semantics. Public generalization excludes slice-level core observations whose public robustness or utility are unsupported. raw_* fields preserve failure-diagnostic strict aggregation, including raw_core_score_strict for strict transfer and scale diagnostics.",
      "robustness": "public robustness is computed from reviewer-safe core attacks only; stress attacks are exported separately through stress_robustness and table-first breakdowns",
      "table_first_diagnostics": "attack_tier and attack_robustness are release-facing table/export surfaces used for per-attack interpretation rather than top-level scorecard scalar fields.",
      "compatibility_aliases": "record.robustness_score and summary.mean_robustness_score remain compatibility aliases for legacy attack-outcome fields. Release-facing summaries should prefer attack_outcome_score and mean_attack_outcome_score naming.",
      "efficiency": "standalone token-normalized clean-vs-watermarked generation-stage diagnostic surface",
      "efficiency_conditioned": "efficiency term conditioned on utility and included in core_score",
      "efficiency_scope": "efficiency and efficiency_conditioned are computed only from generation-stage clean/watermarked token-normalized timing, not from attack, validation, detection, or total-example timing",
      "orthogonality": "released scorecard fields are intentionally not orthogonal because CodeMarkScore exposes both intermediate diagnostics and the final composed headline score",
      "headline_role": "CodeMarkScore is a secondary summary metric. Exact-value tables, factor decompositions, and per-attack/per-tier breakdowns are the primary evidence surfaces."
    }
  },
  "timing_contract": {
    "efficiency_inputs": [
      "summary.stage_timing.clean_generation_seconds_per_1k_token",
      "summary.stage_timing.watermarked_generation_seconds_per_1k_token",
      "scorecard.efficiency",
      "scorecard.efficiency_conditioned"
    ],
    "descriptive_only_stage_timing_fields": [
      "summary.stage_timing.attack_seconds_total",
      "summary.stage_timing.validation_seconds_total",
      "summary.stage_timing.detection_seconds_total",
      "summary.stage_timing.total_example_seconds_total"
    ],
    "notes": {
      "generation_stage_only": "The public efficiency semantics use only clean-vs-watermarked generation-stage token-normalized timing.",
      "descriptive_only": "Full-pipeline attack, validation, detection, and total-example timing remain descriptive systems outputs and are not CodeMarkScore inputs.",
      "summary_export_contract": "Tracked full-run summary figures and tables are documented separately in results/export_schema.json."
    }
  }
